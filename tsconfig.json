{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["es2019", "dom"],
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"],
      "@test/*": ["test/*"],
      "@language/*": ["src/language/*"],
      "@propositional/*": ["src/language/propositional/*"],
      "@quantificational/*": ["src/language/quantificational/*"],
      "@engine/*": ["src/engine/*"],
      "@nlp/*": ["src/engine/nlp/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
